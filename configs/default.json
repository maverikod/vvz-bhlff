{
  "domain": {
    "L": 1.0,
    "N": 256,
    "dimensions": 3,
    "N_phi": 32,
    "N_t": 64,
    "T": 1.0
  },
  "physics": {
    "mu": 1.0,
    "beta": 1.0,
    "lambda": 0.0,
    "nu": 1.0,
    "phase_velocity": 1e15
  },
  "solver": {
    "precision": "float64",
    "fft_plan": "MEASURE",
    "tolerance": 1e-12,
    "max_iterations": 1000
  },
  "output": {
    "save_fields": true,
    "save_spectra": true,
    "save_analysis": true,
    "format": "hdf5",
    "output_dir": "output"
  },
  "visualization": {
    "plot_format": "png",
    "dpi": 300,
    "style": "seaborn-v0_8",
    "color_map": "viridis"
  },
  "analysis": {
    "compute_energy": true,
    "compute_topology": true,
    "compute_coherence": true,
    "save_metrics": true
  }
}
