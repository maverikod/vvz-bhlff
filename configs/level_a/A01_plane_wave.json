{
  "test_id": "A01",
  "test_name": "plane_wave",
  "description": "Plane wave validation for Level A basic solvers",
  "domain": {
    "L": 1.0,
    "N": 256,
    "dimensions": 3
  },
  "physics": {
    "mu": 1.0,
    "beta": 1.0,
    "lambda": 0.1,
    "nu": 1.0
  },
  "time": {
    "dt": 1e-3,
    "T": 1.0,
    "scheme": "exponential"
  },
  "forcing": {
    "type": "plane_wave",
    "modes": [[4,0,0], [0,4,0], [3,3,2], [2,2,4]],
    "amplitudes": [[1.0, 0.0], [1.0, 0.0], [1.0, 0.0], [1.0, 0.0]],
    "omega": 0.0
  },
  "output": {
    "dir": "output/A01",
    "save_fields": true,
    "save_spectra": true,
    "save_analysis": true,
    "format": "hdf5"
  },
  "tolerance": {
    "error_L2": 1e-12,
    "anisotropy": 1e-12,
    "residual": 1e-12
  },
  "seed": 42
}
