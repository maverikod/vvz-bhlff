{
  "test_id": "A03",
  "test_name": "zero_mode",
  "description": "Zero mode handling for λ=0 case",
  "domain": {
    "L": 1.0,
    "N": 256,
    "dimensions": 3
  },
  "physics": {
    "mu": 1.0,
    "beta": 1.0,
    "lambda": 0.0,
    "nu": 1.0
  },
  "time": {
    "dt": 1e-3,
    "T": 1.0,
    "scheme": "exponential"
  },
  "forcing": {
    "type": "zero_mode_test",
    "test_cases": [
      {
        "name": "constant_source",
        "description": "Constant source violating ŝ(0) = 0 condition"
      },
      {
        "name": "zero_dc_source",
        "description": "Source with zero DC component"
      },
      {
        "name": "plane_wave",
        "description": "Plane wave source with zero DC"
      }
    ]
  },
  "output": {
    "dir": "output/A03",
    "save_fields": true,
    "save_spectra": true,
    "save_analysis": true,
    "format": "hdf5"
  },
  "tolerance": {
    "error_L2": 1e-12,
    "zero_mode_detection": 1e-12,
    "residual": 1e-12
  },
  "seed": 42
}
