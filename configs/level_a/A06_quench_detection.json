{
  "test_id": "A06",
  "test_name": "quench_detection",
  "domain": { "L": 1.0, "N": 64, "dimensions": 7 },
  "physics": { "mu": 1.0, "beta": 1.0, "lambda": 0.1 },
  "source": {
    "type": "neutralized_gaussian",
    "sigma": 0.02,
    "center": [0.5, 0.5, 0.5]
  },
  "quench": {
    "amplitude_threshold": 0.5,
    "detuning_threshold": 0.1,
    "gradient_threshold": 10.0
  },
  "cuda": {
    "use_cuda": true,
    "gpu_memory_ratio": 0.8,
    "block_processing": true,
    "vectorized_operations": true
  },
  "tolerance": {
    "detection_accuracy": 0.05,
    "map_stability": 0.01
  }
}

