{
  "test_id": "A11",
  "test_name": "scale_length",
  "description": "Length scale invariance test",
  "domain": {
    "L": 1.0,
    "N": 256,
    "dimensions": 3
  },
  "physics": {
    "mu": 1.0,
    "beta": 1.0,
    "lambda": 0.1,
    "nu": 1.0
  },
  "time": {
    "dt": 1e-3,
    "T": 1.0,
    "scheme": "exponential"
  },
  "forcing": {
    "type": "scale_invariance",
    "test_cases": [
      {
        "name": "case_1",
        "L": 1.0,
        "N": 256
      },
      {
        "name": "case_2", 
        "L": 2.0,
        "N": 512
      }
    ]
  },
  "output": {
    "dir": "output/A11",
    "save_fields": true,
    "save_spectra": true,
    "save_analysis": true,
    "format": "hdf5"
  },
  "tolerance": {
    "invariance_error": 1e-12,
    "scale_factor": 1e-12
  },
  "seed": 42
}
