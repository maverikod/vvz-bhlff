{
  "domain": {
    "L": 1.0,
    "N": 256,
    "dimensions": 3,
    "periodic": true
  },
  "physics": {
    "mu": 1.0,
    "beta": 1.0,
    "lambda": 0.0,
    "nu": 1.0
  },
  "solver": {
    "precision": "float64",
    "fft_plan": "MEASURE",
    "tolerance": 1e-12,
    "max_iterations": 1000
  },
  "benchmarks": {
    "stationary": {
      "test_cases": [
        {
          "name": "plane_wave_single",
          "source_type": "plane_wave",
          "k_mode": [4, 0, 0],
          "amplitude": 1.0
        },
        {
          "name": "plane_wave_multiple",
          "source_type": "plane_wave",
          "k_modes": [[4, 0, 0], [0, 4, 0], [3, 3, 2]],
          "amplitudes": [1.0, 1.0, 1.0]
        },
        {
          "name": "gaussian_source",
          "source_type": "gaussian",
          "center": [0.5, 0.5, 0.5],
          "width": 0.1,
          "amplitude": 1.0
        }
      ]
    },
    "time_dependent": {
      "test_cases": [
        {
          "name": "harmonic_source",
          "source_type": "harmonic",
          "k_mode": [4, 0, 0],
          "frequency": 1.0,
          "amplitude": 1.0,
          "t_final": 1.0,
          "dt": 0.01
        },
        {
          "name": "decaying_source",
          "source_type": "exponential_decay",
          "k_mode": [4, 0, 0],
          "decay_rate": 0.5,
          "amplitude": 1.0,
          "t_final": 2.0,
          "dt": 0.01
        }
      ]
    }
  },
  "performance": {
    "measure_timing": true,
    "measure_memory": true,
    "measure_accuracy": true,
    "warmup_runs": 3,
    "measurement_runs": 10
  },
  "output": {
    "save_fields": true,
    "save_spectra": true,
    "save_analysis": true,
    "format": "hdf5"
  },
  "seed": 42
}
