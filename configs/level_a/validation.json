{
  "domain": {
    "L": 1.0,
    "N": 64,
    "dimensions": 3,
    "N_phi": 16,
    "N_t": 32,
    "T": 0.5
  },
  "physics": {
    "mu": 1.0,
    "beta": 1.0,
    "lambda": 0.1,
    "nu": 1.0,
    "phase_velocity": 1e15
  },
  "solver": {
    "precision": "float64",
    "fft_plan": "MEASURE",
    "tolerance": 1e-10,
    "max_iterations": 500
  },
  "validation": {
    "test_analytical_solution": true,
    "test_conservation": true,
    "test_symmetry": true,
    "test_scaling": true,
    "reference_tolerance": 1e-8
  },
  "output": {
    "save_fields": true,
    "save_spectra": false,
    "save_analysis": true,
    "format": "hdf5",
    "output_dir": "output/level_a/validation"
  }
}
