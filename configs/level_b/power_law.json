{
  "domain": {
    "L": 2.0,
    "N": 128,
    "dimensions": 3,
    "N_phi": 32,
    "N_t": 64,
    "T": 1.0
  },
  "physics": {
    "mu": 1.0,
    "beta": 1.5,
    "lambda": 0.0,
    "nu": 1.0,
    "phase_velocity": 1e15
  },
  "solver": {
    "precision": "float64",
    "fft_plan": "MEASURE",
    "tolerance": 1e-12,
    "max_iterations": 1000
  },
  "analysis": {
    "power_law_range": [0.1, 10.0],
    "power_law_bins": 100,
    "fit_method": "least_squares",
    "exponent_tolerance": 0.1
  },
  "output": {
    "save_fields": true,
    "save_spectra": true,
    "save_analysis": true,
    "format": "hdf5",
    "output_dir": "output/level_b/power_law"
  }
}
